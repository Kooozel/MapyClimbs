{
  "manifest_version": 3,
  "name": "Mapy.cz Climb Analyzer",
  "version": "0.5.5",
  "description": "Analyzes GPX files exported from Mapy.cz and displays climbs with gradient-colored segments and difficulty scores.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://mapy.cz/*",
    "https://*.mapy.cz/*",
    "https://mapy.com/*",
    "https://*.mapy.com/*"
  ],
  "action": {
    "default_title": "Climb Analyzer",
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "images/icon-16.svg",
      "48":  "images/icon-48.svg",
      "128": "images/icon-128.svg"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mapy.cz/*",
        "https://*.mapy.cz/*",
        "https://mapy.com/*",
        "https://*.mapy.com/*"
      ],
      "js": [
        "gpx-interceptor.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://mapy.cz/*",
        "https://*.mapy.cz/*",
        "https://mapy.com/*",
        "https://*.mapy.com/*"
      ],
      "js": [
        "gpx-parser.js",
        "map-inject.js"
      ],
      "css": [
        "map-inject.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["gpx-interceptor-injected.js"],
      "matches": [
        "https://mapy.cz/*",
        "https://*.mapy.cz/*",
        "https://mapy.com/*",
        "https://*.mapy.com/*"
      ]
    }
  ],
  "icons": {
    "16": "images/icon-16.svg",
    "48": "images/icon-48.svg",
    "128": "images/icon-128.svg"
  }
}
