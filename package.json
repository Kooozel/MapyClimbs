{
  "name": "climb",
  "version": "1.0.0",
  "description": "MapyClimbs Chrome extension",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "pack": "npm run build && web-ext build --config=web-ext.config.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ vite.config.ts eslint.config.js",
    "lint:fix": "eslint src/ vite.config.ts --fix",
    "lint:ext": "npm run build && web-ext lint --config=web-ext.config.mjs",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^1.0.14",
    "@eslint/js": "^9.0.0",
    "@types/chrome": "^0.1.38",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "web-ext": "^10.1.0"
  }
}
