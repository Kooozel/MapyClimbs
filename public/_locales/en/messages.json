    "description": "Message shown when no climbs are found"
  },
  "panelClimbsDetectedSingular": {
    "message": "1 climb detected",
    "description": "Section label when exactly one climb is found"
  },
  "panelClimbsDetectedPlural": {
    "message": "$COUNT$ climbs detected",
    "description": "Section label when multiple climbs are found",
    "placeholders": {
      "count": { "content": "$1", "example": "3" }
    }
  }
