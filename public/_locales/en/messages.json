{
  "extName": {
    "message": "MapyClimbs: GPX Climb Analyzer",
    "description": "Extension name"
  },
  "extDescription": {
    "message": "Auto-detect every climb on your Mapy.com route — elevation charts, category grades, VAM, and live map pins injected right into the sidebar.",
    "description": "Extension description"
  },

  "popupStatusNone": {
    "message": "No GPX captured yet",
    "description": "Status when no GPX has been captured"
  },
  "popupStatusCaptured": {
    "message": "GPX captured at $TIME$, $DATE$",
    "description": "Status when a GPX was captured",
    "placeholders": {
      "time": { "content": "$1", "example": "14:32" },
      "date": { "content": "$2", "example": "Apr 2" }
    }
  },
  "popupClimbsDetected": {
    "message": "$COUNT$ climbs detected • $DISTANCE$ km total distance",
    "description": "Climb stats summary line",
    "placeholders": {
      "count": { "content": "$1", "example": "3" },
      "distance": { "content": "$2", "example": "42.5" }
    }
  },
  "popupInfoText": {
    "message": "Automatically captures GPX exports from Mapy.cz route planner and detects climbs with ProCyclingStats difficulty scoring.",
    "description": "Info section description"
  },
  "popupRetryBtn": {
    "message": "↻ Retry Analysis",
    "description": "Retry analysis button"
  },
  "popupHowToTitle": {
    "message": "How to use",
    "description": "How-to section heading"
  },
  "popupHowToStep1": {
    "message": "Open the <strong>Route Planner</strong> on Mapy.cz",
    "description": "How-to step 1 (may contain HTML)"
  },
  "popupHowToStep2": {
    "message": "Plan your route",
    "description": "How-to step 2"
  },
  "popupHowToStep3": {
    "message": "Click <strong>MapyClimbs</strong> in the route toolbar — the extension fetches &amp; analyzes the GPX silently",
    "description": "How-to step 3 (may contain HTML)"
  },
  "popupHowToStep4": {
    "message": "Climb cards and map pins appear instantly in the sidebar",
    "description": "How-to step 4"
  },
  "popupCatTitle": {
    "message": "Categories",
    "description": "Categories section heading"
  },
  "popupFormula": {
    "message": "Score = dist(km) × avg grade(%) × 100",
    "description": "Scoring formula label"
  },
  "popupBmcHeading": {
    "message": "Enjoying MapyClimbs?",
    "description": "Support section heading"
  },
  "popupBmcDesc": {
    "message": "Every climb starts with a single pedal stroke. If MapyClimbs helps you conquer yours, consider fuelling the developer with a coffee! ☕",
    "description": "Support section description"
  },
  "popupBmcBtn": {
    "message": "☕ Support this project",
    "description": "Buy me a coffee button"
  },

  "panelTitle": {
    "message": "MapyClimbs",
    "description": "Sidebar panel and toolbar button title"
  },
  "panelRouteOverview": {
    "message": "Route overview",
    "description": "Route overview section heading"
  },
  "panelKmTotal": {
    "message": "km total",
    "description": "Stat label for total distance"
  },
  "panelMClimbing": {
    "message": "m climbing",
    "description": "Stat label for total elevation gain"
  },
  "panelMaxGrade": {
    "message": "max grade",
    "description": "Stat label for maximum gradient"
  },
  "panelKmClimbs": {
    "message": "km climbs",
    "description": "Stat label for total climbing distance"
  },
  "panelClimb": {
    "message": "Climb $NUMBER$",
    "description": "Climb card title",
    "placeholders": {
      "number": { "content": "$1", "example": "1" }
    }
  },
  "panelCat": {
    "message": "Cat $CAT$",
    "description": "Category badge label",
    "placeholders": {
      "cat": { "content": "$1", "example": "HC" }
    }
  },
  "panelDistance": { "message": "Distance", "description": "Climb stat label" },
  "panelElevation": { "message": "Elevation", "description": "Climb stat label" },
