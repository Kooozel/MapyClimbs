  "panelSummit": { "message": "Summit", "description": "Climb stat label" },
  "panelSummitAt": { "message": "Summit at", "description": "Climb stat label for summit km" },
  "panelEstTime": { "message": "Est. time", "description": "Climb meta label for estimated time" },
  "panelVam": { "message": "VAM", "description": "Climb meta label" },
  "panelFietsIndex": { "message": "Fiets index", "description": "Climb meta label" },
